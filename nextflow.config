params {
  // SHARE-seq read structure (after demux: R1 = cDNA, R2 = UMI + cDNA)
  umi_len       = 10                     // UMI length (first N bases of R2)
  total_bc_len  = 24                     // total cell barcode length (3×8bp) prepended to R2

  // Species / alignment mode
  species_model       = 'human'    // 'human', 'mouse', or 'hybrid'
  human_genome_build  = 'hg19'     // when species_model=human: 'hg19' or 'hg38'
  star_alignment_mode = 'single'   // 'single' (CB_UMI_Complex) or 'paired' (CB_UMI_Simple)

  // Fixed reference/index set (selected by species_model + human_genome_build)
  hybrid_fasta      = '/home/yli11/dirs/pipelines/hg38_mm10/hg38_mm10.fa'
  hybrid_gtf        = '/home/yli11/dirs/pipelines/hg38_mm10/hg_mm_gencode.annot.gtf'
  hybrid_bwa_prefix = '/home/yli11/dirs/pipelines/hg38_mm10/hg38_mm10.fa'
  hybrid_star_index = '/home/yli11/dirs/pipelines/hg38_mm10/share_seq_index/'

  hg19_fasta      = '/home/yli11/Data/Human/hg19/fasta/hg19.fa'
  hg19_gtf        = '/home/yli11/dirs/pipelines/hg38/cellranger_arc/HBG1_HBA1_mask/gencode.v32.primary_assembly.annotation.gtf.filtered.rmHBGnoise.gtf'
  hg19_bwa_prefix = '/home/yli11/Data/Human/hg19/fasta/hg19.fa'
  hg19_star_index = '/home/yli11/dirs/pipelines/hg19/share_seq_index/'

  hg38_fasta      = '/home/yli11/Data/Human/hg38/bwa_16a_index/hg38.fa'
  hg38_gtf        = '/home/yli11/dirs/pipelines/hg38/cellranger_arc/HBG1_HBA1_mask/gencode.v32.primary_assembly.annotation.gtf.filtered.rmHBGnoise.gtf'
  hg38_bwa_prefix = '/home/yli11/Data/Human/hg38/bwa_16a_index/hg38.fa'
  hg38_star_index = '/home/yli11/dirs/pipelines/hg38/share_seq_index/'

  mm10_fasta      = '/home/yli11/Data/Mouse/mm10/fasta/mm10.fa'
  mm10_gtf        = '/home/yli11/dirs/pipelines/hg38_mm10/gencode.vM27.annotation.gtf'
  mm10_bwa_prefix = '/home/yli11/Data/Mouse/mm10/bwa_16a_index/mm10.fa'
  mm10_star_index = '/home/yli11/dirs/pipelines/mm10/share_seq_index/'

  // Barcode whitelist
  // barcodes_8bp_file: one 8bp barcode per line
  // barcodes_rc: if true, reverse-complement barcodes before use in all steps
  barcodes_8bp_file = 'barcodes_RC.txt'
  barcodes_rc       = false

  // Optional fastp trimming (adapter removal + quality base trimming).
  // R1 (cDNA): standard fastp. R2 (UMI+cDNA): first umi_len bases protected, remainder trimmed.
  // Read-dropping filters disabled to keep R1/R2 in sync.
  trim_reads = false


  // ATAC cell quality thresholds
  atac_min_frags_for_cell = 1000
  atac_min_tss_for_cell   = 4


  // Demultiplexing — input files are expected inside raw_fastq/ directory.
  // Provide filenames (not full paths); they are resolved relative to raw_fastq/.
  raw_fastq           = 'RAW_FASTQ'
  undetermined_r1     = null   // e.g. 'Undetermined_S0_L001_R1_001.fastq.gz'
  undetermined_r2     = null   // e.g. 'Undetermined_S0_L001_R2_001.fastq.gz'
  sgrna_undetermined_r1 = 'sgRNA_Undetermined_S0_R1_001.fastq.gz'
  sgrna_undetermined_r2 = 'sgRNA_Undetermined_S0_R2_001.fastq.gz'
  demux_mismatches    = 1      // allowed mismatches for sample index matching
  // Larger chunks → fewer merge steps; smaller → more parallel DEMULTIPLEX tasks.
  split_reads         = 4000000
  // Cap concurrent RNA/ATAC demux chunk jobs (raise on a cluster, lower on one node).
  demux_max_forks     = 16
  // cutadapt -j for sgRNA demux (single task; keep ≤ cores on the node).
  sgrna_cutadapt_jobs = 8
  split_fastq_bin     = '/home/yli11/HemTools/bin/splitFastq'

  // sample_barcode_file must contain sample metadata used for routing:
  //   - column 1: sample name
  //   - column 3: sample type (RNA or ATAC)
  // RNA samples run full workflow; ATAC samples stop after FASTQC_DEMUX.
  sample_barcode_file = null


  // sgRNA: SHARE_seq_pipeline share_seq_step2_rename_fastq.py then match_gRNA.py (requires utils.py)
  share_seq_pipeline_dir    = '/home/yli11/Tools/SHARE_seq_pipeline'
  rename_fastq_script       = '/home/yli11/Tools/SHARE_seq_pipeline/share_seq_step2_rename_fastq.py'
  match_grna_script         = '/home/yli11/Tools/SHARE_seq_pipeline/match_gRNA.py'
  match_grna_start          = 43
}

executor {
  queueSize = 200
}

process {
  executor = 'lsf'
  queue    = 'standard'
  cpus     = 8
  memory   = '12 GB'

  withName: DEMULTIPLEX {
    cpus     = 2
    memory   = '12 GB'
    maxForks = params.demux_max_forks
    errorStrategy = 'retry'
    maxRetries    = 2
  }
  withName: SGRNA_DEMULTIPLEX_CUTADAPT {
    cpus   = params.sgrna_cutadapt_jobs
    memory = '8 GB'
  }
  withName: SPLIT_UNDETERMINED_FASTQ {
    cpus   = 4
    memory = '16 GB'
  }
  withName: MERGE_DEMUX_CHUNKS {
    cpus   = 4
    memory = '16 GB'
  }
  withName: RENAME_FASTQ {
    cpus   = 1
    memory = '8 GB'
  }
  withName: FASTQC_DEMUX {
    cpus   = 4
    memory = '12 GB'
  }
  withName: FASTQC_TRIMMED {
    cpus   = 4
    memory = '12 GB'
  }
  withName: DETERMINE_READ_LENGTH {
    cpus   = 1
    memory = '2 GB'
  }
  withName: POLYT_FILTER {
    cpus   = 4
    memory = '16 GB'
  }
  withName: TRIM_R1 {
    cpus   = 4
    memory = '16 GB'
  }
  withName: TRIM_R2_PROTECTED {
    cpus   = 4
    memory = '16 GB'
  }
  withName: PREPEND_HEADER_BARCODES {
    cpus   = 4
    memory = '16 GB'
  }
  withName: BWA_INDEX {
    cpus   = 16
    memory = '64 GB'
  }
  withName: BWA_ALIGN_ATAC {
    cpus   = 8
    memory = '32 GB'
  }
  withName: STAR_INDEX {
    memory = '64 GB'
    cpus   = 8
  }
  withName: STARSOLO_SINGLE {
    memory = '40 GB'
    cpus   = 8
  }
  withName: STARSOLO_PAIRED {
    memory = '48 GB'
    cpus   = 8
  }
  withName: KNEE_PLOT {
    cpus   = 1
    memory = '4 GB'
  }
  withName: BARNYARD_PLOT {
    cpus   = 1
    memory = '4 GB'
  }
  withName: HYBRID_SPLIT_SPECIES {
    cpus   = 2
    memory = '8 GB'
  }
  withName: BUILD_PAIRED_WHITELIST {
    cpus   = 1
    memory = '2 GB'
  }
  withName: BUILD_SAMPLE_MANIFESTS {
    cpus   = 1
    memory = '2 GB'
  }
  withName: SGRNA_ANALYSIS {
    cpus   = 2
    memory = '8 GB'
  }
  withName: CELL_OVERLAP_BY_GROUP {
    cpus   = 1
    memory = '4 GB'
  }
  withName: BUILD_QC_HTML {
    cpus   = 1
    memory = '4 GB'
  }
}

