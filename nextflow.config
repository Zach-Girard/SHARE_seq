params {
  raw_fastq     = 'RAW_FASTQ'
  genomes_dir   = 'Genomes'
  gtf_dir       = 'GTF'

  // High-level switches
  skip_demux    = false    // true if FASTQs are already demultiplexed
  skip_trim     = false    // true if you have already done adapter/quality trimming
  skip_polyt    = false    // true if you do not want to run Poly-T filtering on R3

  // SHARE-seq read structure
  umi_len       = 10       // default UMI length in R3
  bc_coords     = '15-23,53-61,91-99'  // default 1-based barcode positions in R2

  // Species / alignment mode
  species_model       = 'human'   // one of: 'human', 'mouse', 'hybrid'
  star_alignment_mode = 'single'  // 'single' or 'paired' for STARsolo

  // Barcode configuration (applies to all modes)
  // barcodes_8bp_file: user-provided 8bp barcode list (one per line)
  // barcodes_rc: if true, pipeline reverse complements these barcodes before use
  barcodes_8bp_file = 'barcodes_RC.txt'
  barcodes_rc       = false
}

process {
  executor = 'local'
  cpus     = 2
  memory   = '4 GB'
}

profiles {
  standard {
    process.executor = 'local'
  }

  // Recommended LSF profile for HPC clusters.
  // Adjust queue, project, and resource limits to match your site.
  lsf {
    process.executor = 'lsf'
    process.queue    = 'general'      // recommended default queue
    process.cpus     = 4              // default cores per task
    process.memory   = '16 GB'        // default memory per task

    // Use a fast scratch/work directory if available
    workDir = "${System.getenv('LSF_SCRATCH') ?: '/scratch/' + System.getenv('USER') + '/nextflow_work'}"
  }
}

