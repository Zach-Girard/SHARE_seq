params {
  raw_fastq     = 'demux'
  genomes_dir   = 'Genomes'
  gtf_dir       = 'GTF'

  // SHARE-seq read structure
  umi_len       = 10       // default UMI length in R3
  bc_coords     = '15-23,53-61,91-99'  // default 1-based barcode positions in R2

  // Species / alignment mode
  species_model       = 'human'   // one of: 'human', 'mouse', 'hybrid'
  star_alignment_mode = 'paired'  // 'single' or 'paired' for STARsolo

  // Barcode configuration (applies to all modes)
  // barcodes_8bp_file: user-provided 8bp barcode list (one per line)
  // barcodes_rc: if true, pipeline reverse complements these barcodes before use
  barcodes_8bp_file = 'barcodes_RC.txt'
  barcodes_rc       = false

  // Optional fastp trimming (adapter/quality).
  // R1 is trimmed normally; R3 protects the first umi_len bases (UMI) from trimming.
  // Set to true to enable, false to skip (default).
  trim_reads = false
}

process {
  executor = 'lsf'
  cpus     = 8
  memory   = '40 GB'
}

profiles {
  standard {
    process.executor = 'lsf'
  }

  // Local profile for workstation/laptop testing.
  // Uses moderate resources suitable for a single machine.
  local {
    process.executor = 'local'
    process.cpus     = 4
    process.memory   = '16 GB'
  }

  // Recommended LSF profile for HPC clusters.
  // Adjust queue, project, and resource limits to match your site.
  lsf {
    process.executor = 'lsf'
    process.queue    = 'standard'    // use bqueues to find less-busy queues
    process.cpus     = 8              // default cores per task
    process.memory   = '40 GB'        // default memory per task

    // Lightweight processes: request fewer resources so they start faster in the queue
    withName: DEMULTIPLEX_PLACEHOLDER {
      cpus   = 1
      memory = '2 GB'
    }
    withName: FASTQC_RAW {
      cpus   = 2
      memory = '4 GB'
    }
    withName: FASTQC_TRIMMED {
      cpus   = 2
      memory = '4 GB'
    }
    withName: DETERMINE_READ_LENGTH {
      cpus   = 1
      memory = '2 GB'
    }
    withName: POLYT_FILTER {
      cpus   = 2
      memory = '8 GB'
    }
    withName: TRIM_R1 {
      cpus   = 4
      memory = '8 GB'
    }
    withName: TRIM_R3_PROTECTED {
      cpus   = 4
      memory = '8 GB'
    }
    withName: ADD_R2_BARCODES_TO_R3 {
      cpus   = 2
      memory = '8 GB'
    }

    // Memory-intensive STAR processes (override defaults)
    withName: STAR_INDEX {
      memory = '64 GB'   // genome indexing: human ~30 GB, hybrid ~60 GB
      cpus   = 8
    }
    withName: STARSOLO_SINGLE {
      memory = '40 GB'   // alignment: scales with read count
      cpus   = 8
    }
    withName: STARSOLO_PAIRED {
      memory = '48 GB'   // paired-end alignment typically needs more
      cpus   = 8
    }
    withName: KNEE_PLOT {
      cpus   = 1
      memory = '4 GB'
    }
    withName: BARNYARD_PLOT {
      cpus   = 1
      memory = '4 GB'
    }
    withName: HYBRID_SPLIT_SPECIES {
      cpus   = 2
      memory = '8 GB'
    }
    withName: PAIRED_BARCODE_MATCH {
      cpus   = 2
      memory = '8 GB'
    }
    withName: BUILD_PAIRED_WHITELIST {
      cpus   = 1
      memory = '2 GB'
    }
  }
}

