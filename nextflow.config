params {
  // Directory containing R1/R2/R3 *.fastq.gz files (relative to project root or absolute)
  raw_fastq     = 'demux'
  genomes_dir   = 'Genomes'
  gtf_dir       = 'GTF'

  // SHARE-seq read structure
  umi_len       = 10                     // UMI length (first N bases of R3)
  bc_coords     = '15-23,53-61,91-99'   // barcode positions in R2 (0-based, exclusive end)

  // Species / alignment mode
  species_model       = 'human'    // 'human', 'mouse', or 'hybrid'
  star_alignment_mode = 'paired'   // 'single' (CB_UMI_Complex) or 'paired' (CB_UMI_Simple)

  // Barcode whitelist
  // barcodes_8bp_file: one 8bp barcode per line
  // barcodes_rc: if true, reverse-complement barcodes before use in all steps
  barcodes_8bp_file = 'barcodes_RC.txt'
  barcodes_rc       = false

  // Optional fastp trimming (adapter removal + quality base trimming).
  // R1: standard fastp. R3: first umi_len bases protected, remainder trimmed.
  // Read-dropping filters disabled to keep R1/R3 in sync.
  trim_reads = false
}

process {
  executor = 'lsf'
  cpus     = 8
  memory   = '40 GB'
}

profiles {
  standard {
    process.executor = 'lsf'
  }

  // Local profile for workstation/laptop testing.
  // Uses moderate resources suitable for a single machine.
  local {
    process.executor = 'local'
    process.cpus     = 4
    process.memory   = '16 GB'
  }

  // Recommended LSF profile for HPC clusters.
  // Adjust queue, project, and resource limits to match your site.
  lsf {
    process.executor = 'lsf'
    process.queue    = 'standard'    // use bqueues to find less-busy queues
    process.cpus     = 8              // default cores per task
    process.memory   = '40 GB'        // default memory per task

    // Per-process resource overrides
    withName: DEMULTIPLEX_PLACEHOLDER {
      cpus   = 1
      memory = '2 GB'
    }
    withName: FASTQC_RAW {
      cpus   = 2
      memory = '4 GB'
    }
    withName: FASTQC_TRIMMED {
      cpus   = 2
      memory = '4 GB'
    }
    withName: DETERMINE_READ_LENGTH {
      cpus   = 1
      memory = '2 GB'
    }
    withName: POLYT_FILTER {
      cpus   = 2
      memory = '8 GB'
    }
    withName: TRIM_R1 {
      cpus   = 4
      memory = '8 GB'
    }
    withName: TRIM_R3_PROTECTED {
      cpus   = 4
      memory = '8 GB'
    }
    withName: ADD_R2_BARCODES_TO_R3 {
      cpus   = 2
      memory = '8 GB'
    }

    // STAR processes (memory-intensive)
    withName: STAR_INDEX {
      memory = '64 GB'
      cpus   = 8
    }
    withName: STARSOLO_SINGLE {
      memory = '40 GB'
      cpus   = 8
    }
    withName: STARSOLO_PAIRED {
      memory = '48 GB'
      cpus   = 8
    }
    withName: KNEE_PLOT {
      cpus   = 1
      memory = '4 GB'
    }
    withName: BARNYARD_PLOT {
      cpus   = 1
      memory = '4 GB'
    }
    withName: HYBRID_SPLIT_SPECIES {
      cpus   = 2
      memory = '8 GB'
    }
    withName: PAIRED_BARCODE_MATCH {
      cpus   = 2
      memory = '8 GB'
    }
    withName: BUILD_PAIRED_WHITELIST {
      cpus   = 1
      memory = '2 GB'
    }
  }
}

