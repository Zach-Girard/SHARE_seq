#!/bin/bash
#BSUB -J grna_cell_tracks
#BSUB -n 8
#BSUB -M 32000
#BSUB -R "rusage[mem=32000MB]"
#BSUB -oo grna_cell_tracks_%J.out
#BSUB -eo grna_cell_tracks_%J.err
#BSUB -W 24:00

# Post-pipeline: per-cell ATAC/RNA BAM + BigWig for cells containing a target gRNA.
# Run from the Nextflow project root after a completed SHARE-seq run.
#
#   dos2unix scripts/grna_cell_tracks.lsf
#   bsub < scripts/grna_cell_tracks.lsf
#
# Edit the variables below before submitting.

cd "$LS_SUBCWD"

# Optional: source conda env (adjust path to your environment.yml install)
# source "$(conda info --base)/etc/profile.d/conda.sh"
# conda activate nextflow-master

PROJECT_DIR="."
SAMPLE_BARCODE_FILE="RAW_FASTQ/input.tsv"
EXPERIMENTAL_GROUP="Group_1"
GRNA_SEQUENCE="GACCGGAACGATCTCGAGCTTTACAGATCGGAAGAGCACACGTCT"
OUT_DIR="grna_tracks/${EXPERIMENTAL_GROUP}_guide"
STAR_MODE="single"

python3 scripts/grna_cell_tracks.py \
  --project-dir "${PROJECT_DIR}" \
  --sample-barcode-file "${SAMPLE_BARCODE_FILE}" \
  --experimental-group "${EXPERIMENTAL_GROUP}" \
  --grna-sequence "${GRNA_SEQUENCE}" \
  --out-dir "${OUT_DIR}" \
  --star-alignment-mode "${STAR_MODE}" \
  --min-grna-count 1 \
  --threads 4 \
  --jobs 4
